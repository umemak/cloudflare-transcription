{
  "name": "cloudflare-transcription",
  "version": "1.0.0",
  "description": "Audio transcription app using Cloudflare Workers, D1, R2, and AI (Whisper)",
  "repository": {
    "type": "git",
    "url": "https://github.com/umemak/cloudflare-transcription.git"
  },
  "author": "umemak",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "npm run build && wrangler dev --port 3000",
    "dev:ai": "npm run build && wrangler dev --port 3000",
    "build": "vite build && npm run fix-routes",
    "fix-routes": "node scripts/fix-routes.js",
    "preview": "wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "deploy:prod": "npm run build && wrangler deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "db:migrate:local": "wrangler d1 migrations apply cloudflare-transcription-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply cloudflare-transcription-db",
    "clean-port": "echo 'Port cleaning not available on Windows'",
    "setup:ffmpeg": "bash scripts/setup-ffmpeg.sh",
    "postinstall": "npm run setup:ffmpeg"
  },
  "dependencies": {
    "hono": "^4.12.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250705.0",
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-dev-server": "^0.18.2",
    "miniflare": "^4.20260301.1",
    "typescript": "^5.0.0",
    "vite": "^6.3.5",
    "wrangler": "^4.71.0"
  }
}
